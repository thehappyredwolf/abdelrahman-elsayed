---
import Anchor from "./common/Anchor.astro";

export type Props = {
	title: string;
	description: string;
	url: string;
	cardImage?: string;
	githubUrl?: string;
	liveUrl?: string;
	tags: string[];
};

const { title, description, url, cardImage, githubUrl, liveUrl, tags } = Astro.props;
---

<div class="relative flex flex-col gap-3 mb-8 hover-zag-dotted-grid">
  <div class="flex flex-col sm:flex-row sm:items-start gap-4">
    {
      cardImage ? (
        <Anchor url={url} aria-label={`${title} project page`} class="shrink-0">
          <img
            src={cardImage}
            alt={`${title} preview image`}
            loading="lazy"
            class="w-20 h-20 rounded-lg object-cover zag-border zag-transition"
          />
        </Anchor>
      ) : null
    }
    <div class="flex flex-col gap-3 w-full">
      <div class="flex flex-col gap-3 sm:flex-row sm:justify-between">
        <Anchor url={url} class="text-xl">
          {title}
        </Anchor>
        <div class="flex gap-2">
          {
            githubUrl ? (
              <Anchor url={githubUrl} class="text-base" external>
                GitHub
              </Anchor>
            ) : null
          }
          {
            liveUrl ? (
              <Anchor url={liveUrl} class="text-base" external>
                Live
              </Anchor>
            ) : null
          }
        </div>
      </div>
      <p class="zag-text zag-transition">
        {description}
      </p>
      <div class="flex flex-row flex-wrap gap-2">
        {
          tags.map((tag) => (
            <span class="-zag-text -zag-bg zag-transition px-2 py-1 text-sm font-semibold">
              {tag}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</div>
